# ============================================================
# SINAN Analytics — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# O .env NUNCA deve ser commitado (está no .gitignore).
# ============================================================

# ── AWS Bedrock ──────────────────────────────────────────────
# Chave de API do Bedrock (curto prazo expira em 12h; longo prazo não expira)
BEDROCK_API_KEY=bedrock-api-key-XXXXXXXXXXXXXXXX
BEDROCK_ENDPOINT=https://bedrock-runtime.us-east-2.amazonaws.com
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
AWS_REGION=us-east-2

# Modelo rápido para etapas leves (classificação de intenção, conversa)
# BEDROCK_FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Alternativa: credenciais AWS completas (no lugar da API key)
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_SESSION_TOKEN=xxxxxxxx

# ── PostgreSQL ────────────────────────────────────────────────
# Atenção: DB_NAME é o database; DB_SCHEMA é o schema das tabelas SINAN
DB_HOST=bigdata.dataiesb.com
DB_PORT=5432
DB_NAME=iesb
DB_SCHEMA=SUS_SINAN
DB_USER=data_iesb
DB_PASSWORD=sua_senha_aqui

# ── Administração ─────────────────────────────────────────────
# Senha das páginas restritas (Configurações). Obrigatória em produção.
# ADMIN_PASSWORD=defina-uma-senha-forte

# ── Comportamento ─────────────────────────────────────────────
MAX_SQL_ROWS=500
SQL_TIMEOUT=30
LOG_LEVEL=INFO
