# ============================================================
# SINAN Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── AWS Bedrock ──────────────────────────────────────────────
# Opção 1: API Key (chave única — recomendado)
BEDROCK_API_KEY=bedrock-api-key-XXXXXXXXXXXXXXXX
BEDROCK_ENDPOINT=https://bedrock-runtime.us-east-1.amazonaws.com
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Opção 2: Credenciais AWS completas (alternativo ao API Key)
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_SESSION_TOKEN=xxxxxxxx    # apenas para credenciais temporárias
# AWS_REGION=us-east-1

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=SUS_SINAN
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ── Comportamento ─────────────────────────────────────────────
MAX_SQL_ROWS=500
SQL_TIMEOUT=30
LOG_LEVEL=INFO
