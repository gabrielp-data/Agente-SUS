  "schema": "SUS_SINAN",
  "notes": [
    "codigo_municipio: código IBGE de 6 dígitos (sem dígito verificador)",
    "Para filtrar por UF, use LEFT(codigo_municipio, 2) = '<codigo_uf>'",
    "Para filtrar por município, use codigo_municipio = '<codigo_ibge>'",
    "ano e mes são campos CHAR — use ano = '2023' (com aspas) ou ano::int = 2023",
    "tipo_municipio é um ENUM — valores típicos: verificar com SELECT DISTINCT tipo_municipio FROM tabela",
    "Tabelas mensais têm casos_mes; tabelas anuais têm casos_ano"
