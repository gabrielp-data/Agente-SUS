# ─────────────────────────────────────────────────────────────────────────────
# MODELO de secrets para o Streamlit Community Cloud.
#
# NÃO coloque valores reais aqui (este arquivo VAI pro GitHub).
# No deploy: copie estas chaves, preencha com os valores reais e cole em
#   share.streamlit.io → seu app → Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

# AWS Bedrock
# Chave de curto prazo: expira em 12h. Quando expirar, basta editar este
# valor no painel (Settings → Secrets) — o app reinicia e pega a nova.
BEDROCK_API_KEY   = "cole-aqui-a-api-key-do-bedrock"
BEDROCK_ENDPOINT  = "https://bedrock-runtime.us-east-2.amazonaws.com"
BEDROCK_MODEL_ID  = "us.anthropic.claude-sonnet-4-6"
AWS_REGION        = "us-east-2"

# PostgreSQL — o host precisa ser acessível pela internet
DB_HOST     = "bigdata.dataiesb.com"
DB_PORT     = "5432"
DB_NAME     = "iesb"
DB_SCHEMA   = "SUS_SINAN"
DB_USER     = "data_iesb"
DB_PASSWORD = "cole-aqui-a-senha"

# Senha das páginas administrativas (Configurações / limpar logs).
# OBRIGATÓRIA em produção — sem ela, qualquer visitante poderia alterar
# o endpoint do Bedrock e capturar a chave de API.
ADMIN_PASSWORD = "defina-uma-senha-forte"

# Opcional: modelo rápido para etapas leves do agente
# BEDROCK_FAST_MODEL_ID = "us.anthropic.claude-haiku-4-5-20251001-v1:0"
